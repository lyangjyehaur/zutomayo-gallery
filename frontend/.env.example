# ==========================================
# ZUTOMAYO MV Gallery - 前端環境變數
# ==========================================

# 後端 API 伺服器位址
# 整合部署時通常為 "/api/mvs"
# 分離部署時請填寫後端網址，例如 "https://api.ztmr.club/api/mvs"
VITE_API_URL=/api/mvs

# Waline 留言板伺服器位址 (必填)
VITE_WALINE_SERVER_URL=https://wl.danndann.cn

# Umami 網站分析 (選填)
# VITE_UMAMI_WEBSITE_ID=
# VITE_UMAMI_SCRIPT_URL=

# Twitter 圖片反代網域 (海外節點，用於大陸用戶)
VITE_TWITTER_PROXY=https://pbs.twimg.com
# Twitter 圖片服務反代網域 (大陸節點 / imgproxy)
VITE_TWITTER_IMG_PROXY=https://img.ztmr.club
# Twitter 影片反代網域 (海外節點，用於大陸用戶)
VITE_TWITTER_VIDEO_PROXY=https://v-proxy.ztmr.club

# ==========================================
# ZUTOMAYO Gallery - 前端環境變數
# ==========================================

# ====================
# API 設定
# ====================
# 後端 API 伺服器的根網址 (不包含 /mvs)
# 開發環境下可留空，Vite 會自動代理
# 生產環境下請填寫完整的後端網址，例如: https://api.ztmy.com/api
VITE_API_ROOT=/api

# ====================
# 圖片代理與加速 (選填)
# ====================
# API 伺服器原始網域 (用於 HTML preconnect)
VITE_API_ORIGIN=https://api.ztmr.club

# Imgproxy 圖片處理伺服器原始網域
VITE_IMGPROXY_ORIGIN=https://img.ztmr.club

# 靜態媒體資源原始網域
VITE_ASSETS_ORIGIN=https://assets.ztmr.club

# Imgproxy 圖片處理伺服器位址 (預設為官方提供)
VITE_TWITTER_IMAGE_SOURCE_HOST=https://pbs.twimg.com
VITE_TWITTER_VIDEO_SOURCE_HOST=https://video.twimg.com
VITE_TWITTER_PROXY_PATH=/ti
VITE_TWITTER_VIDEO_PROXY_PATH=/tv
VITE_YOUTUBE_SOURCE_HOSTS=i.ytimg.com,img.youtube.com,youtube.com
VITE_YOUTUBE_PROXY_PATH=/yi

# 自訂 Cloudflare R2 綁定的自訂網域 (預設為 https://r2.dan.tw)
VITE_R2_DOMAIN=https://r2.dan.tw

# ====================
# 第三方服務 (選填)
# ====================
# Waline 留言板伺服器位址
VITE_WALINE_SERVER_URL=https://comments.ztmr.club

# Unpkg 原始網域 (供 Waline / emoji 套件使用)
VITE_UNPKG_ORIGIN=https://unpkg.com
VITE_WALINE_EMOJI_ORIGIN=https://unpkg.com
VITE_WALINE_EMOJI_FASTLY_ORIGIN=https://fastly.jsdelivr.net/npm
VITE_WALINE_AVATAR_ORIGIN=https://gravatar.com/avatar
VITE_WALINE_AVATAR_MIRROR_ORIGIN=https://cravatar.cn/avatar

# 影音嵌入來源
VITE_YOUTUBE_EMBED_ORIGIN=https://www.youtube.com/embed
VITE_BILIBILI_EMBED_ORIGIN=https://player.bilibili.com/player.html

# Umami（只保留 commons 版本）
# Umami 網站追蹤統計 ID；留空則不啟用
VITE_UMAMI_SECONDARY_WEBSITE_ID=
# commons 站台的追蹤腳本網址
VITE_UMAMI_SECONDARY_HOST_URL=
# commons 腳本掛載的基底路徑
VITE_UMAMI_SECONDARY_BASE_SCRIPT=/commons

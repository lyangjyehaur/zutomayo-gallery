# ==========================================
# ZUTOMAYO Gallery - 前端環境變數
# ==========================================

# ====================
# API 設定
# ====================
# 後端 API 伺服器的完整網址 (包含 /api/mvs)
# 開發環境下可留空，Vite 會自動代理
# 生產環境下請填寫完整的後端網址，例如: https://api.ztmy.com/api/mvs
VITE_API_URL=/api/mvs

# ====================
# 圖片代理與加速 (選填)
# ====================
# Imgproxy 圖片處理伺服器位址 (預設為官方提供)
VITE_TWITTER_IMG_PROXY=https://img.ztmr.club

# 自訂 Cloudflare R2 綁定的自訂網域 (預設為 https://r2.dan.tw)
VITE_R2_DOMAIN=https://r2.dan.tw

# ====================
# 第三方服務 (選填)
# ====================
# Waline 留言板伺服器位址
VITE_WALINE_SERVER_URL=https://wl.danndann.cn

# Umami 網站追蹤統計 ID (留空則不啟用)
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SCRIPT_URL=

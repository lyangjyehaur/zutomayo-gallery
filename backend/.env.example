# ===========================================
# ZUTOMAYO Gallery Backend - Environment Variables
# ===========================================
# 請將此檔複製為 .env 後再填入實際值

# === Server ===
NODE_ENV=development # 運行環境，開發用 development，正式部署用 production
PORT=5010 # 後端監聽埠
TRUST_PROXY=true # 是否信任反向代理，供真實 IP / secure cookie 使用
APP_VERSION= # 應用版本字串，通常由部署流程注入

# === Database (PostgreSQL) ===
DB_HOST=127.0.0.1 # PostgreSQL 主機位址
DB_PORT=5432 # PostgreSQL 連接埠
DB_NAME=zutomayo_gallery # PostgreSQL 資料庫名稱
DB_USER=zutomayo_gallery # PostgreSQL 使用者名稱
DB_PASS= # PostgreSQL 密碼
DB_SCHEMA_MODE=alter # 資料表同步模式：alter / safe / none
DB_GRANT_USER= # 選填，授權給只讀或其他用途的資料庫使用者

# === Redis ===
REDIS_URL=redis://127.0.0.1:6379 # Redis 連線網址

# === Session ===
SESSION_SECRET= # Express session 簽名金鑰，正式環境必填
SESSION_STORE=redis # session 儲存方式：redis / sequelize
SESSION_MAX_AGE_DAYS=7 # session 有效天數
SESSION_COOKIE_DOMAIN= # session cookie 的 domain，留空則使用預設
SESSION_COOKIE_NAME=ztmy.sid # session cookie 名稱

# === Admin Seed ===
ADMIN_SEED_USERNAME=admin # 初始管理員帳號
ADMIN_SEED_PASSWORD= # 初始管理員密碼，首次部署建議填入
ADMIN_PASSWORD= # 備用管理員密碼，會作為 ADMIN_SEED_PASSWORD 的 fallback

# === CORS ===
ALLOWED_ORIGINS=https://mv.ztmr.club # 允許的前端來源，逗號分隔

# === WebAuthn/Passkey ===
EXPECTED_ORIGIN=http://localhost:5173 # WebAuthn 預期來源，需與前端網域一致
RP_ID=localhost # WebAuthn Relying Party ID，通常是網站主網域

# === Meilisearch ===
MEILI_HOST=http://127.0.0.1:7700 # Meilisearch 服務位址
MEILI_MASTER_KEY= # Meilisearch 主金鑰

# === Cloudflare R2 (Image Storage) ===
# R2_ACCOUNT_ID= # Cloudflare R2 Account ID
# R2_ACCESS_KEY_ID= # Cloudflare R2 Access Key ID
# R2_SECRET_ACCESS_KEY= # Cloudflare R2 Secret Access Key
# R2_BUCKET_NAME= # R2 bucket 名稱
# R2_PUBLIC_DOMAIN= # R2 公網域名

# === Imgproxy ===
# IMGPROXY_URL= # Imgproxy 服務位址
# IMGPROXY_KEY= # Imgproxy 簽名用 key
# IMGPROXY_SALT= # Imgproxy 簽名用 salt

# === Waline Webhook ===
WALINE_WEBHOOK_SECRET= # Waline webhook 驗證 token，正式環境建議設定

# === Bark Push Notification ===
# BARK_URL= # Bark 完整 URL，或只填 key

# === Telegram Bot Notification ===
TELEGRAM_BOT_TOKEN= # Telegram Bot API Token
TELEGRAM_CHAT_ID= # Telegram 通知目標 Chat ID

# === Web Push (VAPID) ===
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ztmr.club

# === Twitter RSS ===
TWITTER_RSS_URL= # Twitter RSS 來源網址
TWITTER_MONITOR_CRON= # Twitter 爬蟲排程 cron

# === Email Providers (configure one or more) ===
# --- Tencent SES ---
# TENCENT_SECRET_ID= # 騰訊雲 SES Secret ID
# TENCENT_SECRET_KEY= # 騰訊雲 SES Secret Key
# TENCENT_SES_REGION=ap-hongkong # SES 區域
# TENCENT_SES_ENDPOINT= # SES 自訂 endpoint
# TENCENT_SES_FROM_EMAIL= # 寄件人信箱
# TENCENT_SES_FROM_NAME= # 寄件人名稱
# TENCENT_SES_DEFAULT_LANG=zh-TW # 預設郵件語言

# --- Brevo ---
# BREVO_API_KEY= # Brevo API 金鑰
# BREVO_FROM_EMAIL= # Brevo 寄件人信箱
# BREVO_FROM_NAME= # Brevo 寄件人名稱

# --- Postmark ---
# POSTMARK_SERVER_TOKEN= # Postmark Server Token
# POSTMARK_FROM_EMAIL= # Postmark 寄件人信箱
# POSTMARK_FROM_NAME= # Postmark 寄件人名稱
# POSTMARK_MESSAGE_STREAM=outbound # Postmark message stream

# --- Aliyun DirectMail ---
# ALIYUN_ACCESS_KEY_ID= # 阿里雲 DirectMail Access Key ID
# ALIYUN_ACCESS_KEY_SECRET= # 阿里雲 DirectMail Access Key Secret
# ALIYUN_DM_REGION_ID= # 阿里雲 DirectMail 區域 ID
# ALIYUN_DM_ENDPOINT= # 阿里雲 DirectMail endpoint
# ALIYUN_DM_ACCOUNT_NAME= # 阿里雲 DirectMail 帳號名稱

# === Email Mainland Detection ===
# MAIL_MAINLAND_DOMAINS= # 判定為大陸信箱的完整網域清單
# MAIL_MAINLAND_SUFFIXES= # 判定為大陸信箱的副檔名 / 後綴清單

# === Public Auth ===
PUBLIC_APP_ORIGIN=http://localhost:5173 # 公開登入 / 驗證連結的前端來源

# === Sitemap ===
# SITEMAP_BASE_URL=https://mv.ztmr.club # sitemap 基底網址
# SITEMAP_TWITTER_ASSET_HOST= # sitemap 用的 Twitter 資產主機
# SITEMAP_YOUTUBE_ASSET_HOST= # sitemap 用的 YouTube 資產主機

# === Logging ===
LOG_LEVEL=info # 日誌等級：trace / debug / info / warn / error / fatal

# === Apify (Twitter scraping) ===
# APIFY_API_TOKEN= # Apify API token

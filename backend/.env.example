# ==========================================
# ZUTOMAYO MV Gallery - 後端環境變數
# ==========================================

# 運行連接埠
PORT=5010

# 運行環境 (development 或 production)
NODE_ENV=production

# ====================
# 安全性設定 (⚠️ 必填)
# ====================
# 管理後台登入密碼 (強烈建議修改！)
ADMIN_PASSWORD=zutomayo

# ====================
# CORS 設定 (⚠️ 必填)
# ====================
# 允許跨域的來源，請填寫前端網站的完整網址，多個來源用逗號分隔
# 本地開發時可加上 http://localhost:5173
ALLOWED_ORIGINS=https://mv.ztmr.club,http://localhost:5173

# ====================
# WebAuthn (Passkeys) 設定
# ====================
# 通行密鑰驗證的來源域名 (必須與前端網站的網址完全一致，且必須為 https)
EXPECTED_ORIGIN=https://mv.ztmr.club

# 依賴方 ID (通常為網站的主網域，不包含 https:// 或埠號)
# 例如：如果 EXPECTED_ORIGIN 是 https://mv.ztmr.club，則 RP_ID 應為 mv.ztmr.club
RP_ID=mv.ztmr.club

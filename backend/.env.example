# ==========================================
# ZUTOMAYO Gallery - 後端環境變數
# ==========================================

# ====================
# 伺服器設定
# ====================
PORT=5010
NODE_ENV=development

# ====================
# CORS 設定
# ====================
# 允許跨域請求的來源 (用逗號分隔)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173

# ====================
# 身份驗證與安全
# ====================
# 管理後台登入密碼
ADMIN_PASSWORD=zutomayo

# WebAuthn (通行密鑰) 設定
# 您的前端網站網址，用於驗證 WebAuthn 來源是否合法
EXPECTED_ORIGIN=http://localhost:5173
# 您的主網域，例如: mv.ztmr.club (預設會從 EXPECTED_ORIGIN 自動解析，通常不需手動填寫)
RP_ID=

# ====================
# Image Proxy 安全簽名設定 (必填)
# ====================
# 您的 imgproxy 必須啟用安全簽名驗證 (關閉 insecure 模式)。
# 請填寫對應的 Hex 金鑰與鹽值，前端請求圖片時將透過 /api/system/image/proxy 路由產生安全的 302 重定向。
# 開發環境與生產環境皆需配置此兩項變數。
IMGPROXY_URL=https://img.ztmr.club
IMGPROXY_KEY=
IMGPROXY_SALT=

# ====================
# Cloudflare R2 / S3 儲存設定 (選填)
# ====================
# 僅在執行爬蟲或上傳新圖片時需要
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=

# ====================
# Meilisearch 搜尋引擎設定 (選填)
# ====================
# 開發環境可留空以跳過初始化
MEILI_HOST=
MEILI_MASTER_KEY=

# ====================
# Redis 快取設定 (選填)
# ====================
# 開發環境可留空以跳過連線
REDIS_URL=

# ====================
# Public User Auth (投稿用戶) 設定
# ====================
# 用於產生註冊驗證 / 重設密碼信件中的前端連結
PUBLIC_APP_ORIGIN=http://localhost:5173

# ====================
# 郵件推送（騰訊雲 SES）
# ====================
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SES_REGION=ap-guangzhou
TENCENT_SES_ENDPOINT=ses.tencentcloudapi.com

# ====================
# 郵件推送（阿里雲 DirectMail / 境內備援）
# ====================
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_DM_REGION_ID=cn-hangzhou
ALIYUN_DM_ENDPOINT=dm.aliyuncs.com

# 阿里雲 DirectMail 使用 AccountName 作為發件地址（可依用途分開）
ALIYUN_DM_ACCOUNT_NAME_LOGIN=
ALIYUN_DM_ACCOUNT_NAME_VERIFY=
ALIYUN_DM_ACCOUNT_NAME_RESET=
ALIYUN_DM_ACCOUNT_NAME=

ALIYUN_DM_FROM_ALIAS_LOGIN=
ALIYUN_DM_FROM_ALIAS_VERIFY=
ALIYUN_DM_FROM_ALIAS_RESET=
ALIYUN_DM_FROM_ALIAS=

# ====================
# 郵件推送（Brevo / 海外）
# ====================
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=
BREVO_FROM_LOGIN_EMAIL=
BREVO_FROM_LOGIN_NAME=
BREVO_FROM_VERIFY_EMAIL=
BREVO_FROM_VERIFY_NAME=
BREVO_FROM_RESET_EMAIL=
BREVO_FROM_RESET_NAME=

# ====================
# 郵件推送（Postmark / 海外備援）
# ====================
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_FROM_EMAIL=
POSTMARK_FROM_NAME=
POSTMARK_FROM_LOGIN_EMAIL=
POSTMARK_FROM_LOGIN_NAME=
POSTMARK_FROM_VERIFY_EMAIL=
POSTMARK_FROM_VERIFY_NAME=
POSTMARK_FROM_RESET_EMAIL=
POSTMARK_FROM_RESET_NAME=

# ====================
# 郵件路由規則
# ====================
# 內地郵箱（收件人域名）走騰訊雲（失敗才改走阿里雲）
# 其餘走 Brevo（失敗才改走 Postmark）
# 可用逗號追加自定義域名（小寫）
MAIL_MAINLAND_DOMAINS=
# 額外後綴判斷（逗號分隔，例如：.中国）
MAIL_MAINLAND_SUFFIXES=

# 發件人（可依用途分開設定）
TENCENT_SES_FROM_LOGIN_EMAIL=
TENCENT_SES_FROM_LOGIN_NAME=
TENCENT_SES_FROM_VERIFY_EMAIL=
TENCENT_SES_FROM_VERIFY_NAME=
TENCENT_SES_FROM_RESET_EMAIL=
TENCENT_SES_FROM_RESET_NAME=

# 如你偏好共用同一組發件人，可改用下列兩項（未填時各用途會 fallback）
TENCENT_SES_FROM_EMAIL=
TENCENT_SES_FROM_NAME=

# 模板（建議/多數帳號必填）：騰訊雲 SES「郵件發送」通常要求使用模板發送
TENCENT_SES_TEMPLATE_LOGIN_ID=
TENCENT_SES_TEMPLATE_VERIFY_ID=
TENCENT_SES_TEMPLATE_RESET_ID=

# 多語言模板（選填）：若提供，系統會嘗試從信件連結的 redirect 中推斷 /:lng/ 並選擇對應模板
TENCENT_SES_DEFAULT_LANG=zh-TW
TENCENT_SES_TEMPLATE_VERIFY_ID_ZH_TW=
TENCENT_SES_TEMPLATE_VERIFY_ID_ZH_CN=
TENCENT_SES_TEMPLATE_VERIFY_ID_ZH_HK=
TENCENT_SES_TEMPLATE_VERIFY_ID_EN=
TENCENT_SES_TEMPLATE_VERIFY_ID_JA=
TENCENT_SES_TEMPLATE_RESET_ID_ZH_TW=
TENCENT_SES_TEMPLATE_RESET_ID_ZH_CN=
TENCENT_SES_TEMPLATE_RESET_ID_ZH_HK=
TENCENT_SES_TEMPLATE_RESET_ID_EN=
TENCENT_SES_TEMPLATE_RESET_ID_JA=

# ====================
# 資料庫設定 (開發環境若使用 SQLite 可忽略)
# ====================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=zutomayo_gallery
DB_USER=zutomayo_gallery
DB_PASS=

# 舊庫修復腳本（recover/fix_*）可選覆寫，未填時會 fallback 到 DB_*。
OLD_DB_HOST=
OLD_DB_PORT=
OLD_DB_NAME=
OLD_DB_USER=
OLD_DB_PASS=

# ====================
# Twitter 爬蟲與通知設定 (選填)
# ====================
# 填寫您要監聽的推特 RSS 網址（例如：https://rsshub.app/twitter/user/zutomayo）
# 若未設定此變數，系統將自動停用 BullMQ 的排程爬蟲任務
TWITTER_RSS_URL=

# 設定多久抓取一次（Cron 格式，預設每小時執行一次）
TWITTER_MONITOR_CRON="0 * * * *"

# iOS Bark 推播通知網址（例如：https://api.day.app/您的金鑰）
BARK_URL=

# ====================
# Sitemap 設定（選填）
# ====================
SITEMAP_BASE_URL=
SITEMAP_IMGPROXY_URL=
SITEMAP_TWITTER_ASSET_HOST=
SITEMAP_YOUTUBE_ASSET_HOST=

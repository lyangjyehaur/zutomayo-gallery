# ==========================================
# ZUTOMAYO Gallery - 後端環境變數
# ==========================================

# ====================
# 伺服器設定
# ====================
PORT=5010
NODE_ENV=development

# ====================
# CORS 設定
# ====================
# 允許跨域請求的來源 (用逗號分隔)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173

# ====================
# 身份驗證與安全
# ====================
# 管理後台登入密碼
ADMIN_PASSWORD=zutomayo

# WebAuthn (通行密鑰) 設定
# 您的前端網站網址，用於驗證 WebAuthn 來源是否合法
EXPECTED_ORIGIN=http://localhost:5173
# 您的主網域，例如: mv.ztmr.club (預設會從 EXPECTED_ORIGIN 自動解析，通常不需手動填寫)
RP_ID=

# ====================
# Image Proxy 安全簽名設定 (選填)
# ====================
# 若您的 imgproxy 啟用了安全簽名驗證，請填寫以下資訊。
# 填寫後，前端請求圖片時將透過 /api/system/image/proxy 路由產生安全的 302 重定向
IMGPROXY_URL=https://img.ztmr.club
IMGPROXY_KEY=
IMGPROXY_SALT=

# ====================
# Cloudflare R2 / S3 儲存設定 (選填)
# ====================
# 僅在執行爬蟲或上傳新圖片時需要
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
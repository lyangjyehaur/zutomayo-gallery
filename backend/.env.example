# ===========================================
# ZUTOMAYO Gallery Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# === Server ===
NODE_ENV=development
PORT=5010
TRUST_PROXY=true
APP_VERSION=

# === Database (PostgreSQL) ===
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=zutomayo_gallery
DB_USER=zutomayo_gallery
DB_PASS=
DB_SCHEMA_MODE=alter           # alter | safe | none
DB_GRANT_USER=                 # Optional: grant DB user for read-only access

# === Redis ===
REDIS_URL=redis://127.0.0.1:6379

# === Session ===
SESSION_SECRET=                 # REQUIRED in production!
SESSION_STORE=redis             # redis | sequelize (default: redis in production)
SESSION_MAX_AGE_DAYS=7
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_NAME=ztmy.sid

# === Admin Seed ===
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=            # REQUIRED for first deployment!
ADMIN_PASSWORD=                 # Fallback for ADMIN_SEED_PASSWORD

# === CORS ===
ALLOWED_ORIGINS=https://mv.ztmr.club

# === WebAuthn/Passkey ===
EXPECTED_ORIGIN=http://localhost:5173
RP_ID=localhost

# === Meilisearch ===
MEILI_HOST=http://127.0.0.1:7700
MEILI_MASTER_KEY=

# === Cloudflare R2 (Image Storage) ===
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_DOMAIN=

# === Imgproxy ===
# IMGPROXY_URL=
# IMGPROXY_KEY=
# IMGPROXY_SALT=

# === Waline Webhook ===
WALINE_WEBHOOK_SECRET=          # REQUIRED in production! Set Waline WEBHOOK to: https://your-domain/api/webhook/waline/<THIS_SECRET>

# === Bark Push Notification ===
# BARK_URL=                     # Full URL (https://api.day.app/xxx) or just the key

# === Twitter RSS ===
TWITTER_RSS_URL=
TWITTER_MONITOR_CRON=

# === Email Providers (configure one or more) ===
# --- Tencent SES ---
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_SES_REGION=ap-hongkong
# TENCENT_SES_ENDPOINT=
# TENCENT_SES_FROM_EMAIL=
# TENCENT_SES_FROM_NAME=
# TENCENT_SES_DEFAULT_LANG=zh-TW

# --- Brevo ---
# BREVO_API_KEY=
# BREVO_FROM_EMAIL=
# BREVO_FROM_NAME=

# --- Postmark ---
# POSTMARK_SERVER_TOKEN=
# POSTMARK_FROM_EMAIL=
# POSTMARK_FROM_NAME=
# POSTMARK_MESSAGE_STREAM=outbound

# --- Aliyun DirectMail ---
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_DM_REGION_ID=
# ALIYUN_DM_ENDPOINT=
# ALIYUN_DM_ACCOUNT_NAME=

# === Email Mainland Detection ===
# MAIL_MAINLAND_DOMAINS=
# MAIL_MAINLAND_SUFFIXES=

# === Public Auth ===
PUBLIC_APP_ORIGIN=http://localhost:5173

# === Sitemap ===
# SITEMAP_BASE_URL=https://mv.ztmr.club
# SITEMAP_TWITTER_ASSET_HOST=
# SITEMAP_YOUTUBE_ASSET_HOST=

# === Logging ===
LOG_LEVEL=info                  # trace | debug | info | warn | error | fatal

# === Apify (Twitter scraping) ===
# APIFY_API_TOKEN=

# === Umami Analytics (Server-side Tracking) ===
# UMAMI_API_URL=              # Umami instance URL (e.g., https://analytics.example.com)
# UMAMI_WEBSITE_ID=           # Umami website UUID
